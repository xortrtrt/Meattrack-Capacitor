erDiagram

    DEPARTMENTS {
        bigint department_id PK
        text department_name UK
        text description
        timestamptz created_at
    }

    EMPLOYEES {
        bigint employee_id PK
        bigint department_id FK
        text name
        text position
        text employment_status
        boolean is_department_leader
        timestamptz created_at
    }

    ACCOUNTS {
        bigint account_id PK
        text account_type
        bigint employee_id FK
        bigint reseller_id FK
        text name
        text email UK
        text password_hash
        boolean is_active
        timestamptz created_at
    }

    ACTIVITY_LOGS {
        bigint activity_log_id PK
        bigint account_id FK
        text action
        text entity_type
        bigint entity_id
        timestamptz created_at
    }

    INQUIRIES {
        bigint inquiry_id PK
        text name
        text contact_number
        text email
        text business_name
        text message
        text status
        bigint assigned_team_leader_account_id FK
        bigint reviewed_by_account_id FK
        timestamptz reviewed_at
        timestamptz created_at
    }

    RESELLERS {
        bigint reseller_id PK
        bigint inquiry_id FK,UK
        text business_name
        text contact_person
        text email UK
        text contact_number
        text address
        text reseller_status
        bigint approved_by_account_id FK
        timestamptz approved_at
        timestamptz created_at
    }

    RAW_MATERIALS {
        bigint raw_material_id PK
        text category
        text name UK
        text unit
        numeric reorder_level
        timestamptz created_at
    }

    RAW_MATERIAL_BATCHES {
        bigint raw_material_batch_id PK
        bigint raw_material_id FK
        text batch_code UK
        numeric quantity_received
        numeric quantity_available
        text unit
        date received_date
        date expiry_date
        text quality_status
        timestamptz created_at
    }

    PRODUCTS {
        bigint product_id PK
        text category
        text name UK
        text description
        text unit
        numeric base_price
        numeric reorder_level
        boolean is_active
        timestamptz created_at
    }

    PRODUCT_RECIPES {
        bigint recipe_id PK
        bigint product_id FK
        bigint raw_material_id FK
        numeric quantity_required
        text unit
    }

    PRODUCT_BATCHES {
        bigint product_batch_id PK
        bigint product_id FK
        text batch_code UK
        text source_type
        numeric quantity_received
        numeric quantity_available
        text unit
        date received_date
        date expiry_date
        text quality_status
        timestamptz created_at
    }

    ORDERS {
        bigint order_id PK
        text order_type
        bigint reseller_id FK
        bigint created_by_account_id FK
        bigint approved_by_account_id FK
        timestamptz approved_at
        timestamptz order_date
        text status
        timestamptz fulfilled_at
        numeric total_amount
        text notes
    }

    ORDER_ITEMS {
        bigint order_item_id PK
        bigint order_id FK
        bigint product_id FK
        numeric quantity
        text unit
        numeric unit_price
        numeric line_total
    }

    SALES_REPORTS {
        bigint sales_report_id PK
        text report_source
        bigint submitted_by_account_id FK
        bigint reseller_id FK
        bigint department_id FK
        date period_start
        date period_end
        numeric total_sales
        int total_orders
        text notes
        timestamptz submitted_at
    }

    EMPLOYEE_ATTENDANCE {
        bigint attendance_id PK
        bigint employee_id FK
        date work_date
        text status
        time time_in
        time time_out
        bigint recorded_by_account_id FK
        text notes
        timestamptz created_at
    }

    EMPLOYEE_TASKS {
        bigint task_id PK
        bigint employee_id FK
        bigint assigned_by_account_id FK
        text title
        text description
        date due_date
        text status
        timestamptz completed_at
        timestamptz created_at
    }

    EMPLOYEE_MERIT_EVALUATIONS {
        bigint evaluation_id PK
        bigint employee_id FK
        bigint evaluator_account_id FK
        date period_start
        date period_end
        int attendance_score
        int task_score
        int behavior_score
        numeric overall_score
        text feedback
        timestamptz created_at
    }

    ALERTS {
        bigint alert_id PK
        text alert_type
        text severity
        bigint product_id FK
        bigint product_batch_id FK
        bigint raw_material_id FK
        bigint raw_material_batch_id FK
        text message
        text status
        timestamptz triggered_at
    }

    FORECAST_RUNS {
        bigint forecast_run_id PK
        bigint run_by_account_id FK
        text model_name
        date input_period_start
        date input_period_end
        int forecast_horizon_days
        text status
        timestamptz started_at
        timestamptz completed_at
        text notes
    }

    FORECAST_RESULTS {
        bigint forecast_result_id PK
        bigint forecast_run_id FK
        bigint product_id FK
        date forecast_date
        numeric predicted_quantity
        numeric confidence_lower
        numeric confidence_upper
        timestamptz created_at
    }

    DEPARTMENTS ||--o{ EMPLOYEES : contains
    EMPLOYEES |o--o| ACCOUNTS : "team leader login"
    RESELLERS |o--o| ACCOUNTS : "reseller login"
    ACCOUNTS |o--o{ ACTIVITY_LOGS : records

    ACCOUNTS |o--o{ INQUIRIES : assigned
    ACCOUNTS |o--o{ INQUIRIES : reviews
    INQUIRIES |o--o| RESELLERS : becomes
    ACCOUNTS |o--o{ RESELLERS : approves

    RAW_MATERIALS ||--o{ RAW_MATERIAL_BATCHES : stocked_as
    PRODUCTS ||--o{ PRODUCT_RECIPES : has
    RAW_MATERIALS ||--o{ PRODUCT_RECIPES : required_by
    PRODUCTS ||--o{ PRODUCT_BATCHES : stocked_as
    PRODUCT_BATCHES |o--o{ ALERTS : triggers
    PRODUCTS |o--o{ ALERTS : triggers
    RAW_MATERIAL_BATCHES |o--o{ ALERTS : triggers
    RAW_MATERIALS |o--o{ ALERTS : triggers

    RESELLERS |o--o{ ORDERS : places
    ACCOUNTS |o--o{ ORDERS : creates
    ACCOUNTS |o--o{ ORDERS : approves
    ORDERS ||--o{ ORDER_ITEMS : contains
    PRODUCTS ||--o{ ORDER_ITEMS : ordered_as

    ACCOUNTS |o--o{ SALES_REPORTS : submits
    RESELLERS |o--o{ SALES_REPORTS : reports
    DEPARTMENTS |o--o{ SALES_REPORTS : reports

    EMPLOYEES ||--o{ EMPLOYEE_ATTENDANCE : has
    EMPLOYEES ||--o{ EMPLOYEE_TASKS : assigned
    EMPLOYEES ||--o{ EMPLOYEE_MERIT_EVALUATIONS : evaluated
    ACCOUNTS |o--o{ EMPLOYEE_ATTENDANCE : records
    ACCOUNTS |o--o{ EMPLOYEE_TASKS : assigns
    ACCOUNTS |o--o{ EMPLOYEE_MERIT_EVALUATIONS : evaluates

    ACCOUNTS |o--o{ FORECAST_RUNS : starts
    FORECAST_RUNS ||--o{ FORECAST_RESULTS : produces
    PRODUCTS ||--o{ FORECAST_RESULTS : forecasted

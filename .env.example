# Copy this file to .env, then fill in real local values.

APP_ENV=development
SESSION_SECRET_KEY=replace_with_a_long_random_secret

# Local development database. In production, replace this with the Supabase
# Session pooler URL (port 5432) from Connect; sslmode=require is added
# automatically for Supabase hosts.
DATABASE_URL=postgresql://meattrack:meattrack@127.0.0.1:5433/meattrack
# DATABASE_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
# Public CDN folder used by templates. Leave empty to serve repository images
# from /static/img during local development.
MEDIA_BASE_URL=https://PROJECT_REF.supabase.co/storage/v1/object/public/meattrack-assets/images
# Used only by tools/migrate_images_to_storage.py. Never expose the secret key
# through Render, browser JavaScript, Capacitor, or a committed .env file.
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_public_key
SUPABASE_SECRET_KEY=replace_with_local_migration_secret
CONSENT_VERSION=2026-07-20
POSTGRES_USER=meattrack
POSTGRES_PASSWORD=replace_with_database_password
POSTGRES_DB=meattrack
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_MODEL=openai/gpt-4o-mini

OWNER_PASSWORD=replace_with_owner_demo_password
TEAM_LEADER_PASSWORD=replace_with_team_leader_demo_password
RESELLER_PASSWORD=replace_with_reseller_demo_password
DEFAULT_ACCOUNT_PASSWORD=replace_with_new_account_default_password

# Recommended for Render Free: send OTP/account emails through Brevo HTTPS API.
# BREVO_FROM_EMAIL must be a verified sender in Brevo.
BREVO_API_KEY=replace_with_brevo_api_key
BREVO_FROM_EMAIL=your_verified_sender@gmail.com
BREVO_FROM_NAME=Batangas Premium

# Optional alternate provider: send OTP/account emails through Resend HTTPS API.
# RESEND_FROM_EMAIL must be a verified sender/domain in Resend.
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM_EMAIL="Batangas Premium <noreply@your-verified-domain.com>"

# Optional local fallback: Gmail SMTP works locally, but Render Free blocks SMTP ports.
# Use a Gmail app password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=replace_with_gmail_app_password
SMTP_FROM_EMAIL=your_gmail_address@gmail.com

# Public HTTPS URL where FastAPI is deployed. Used while syncing Capacitor.
MOBILE_APP_URL=https://your-meattrack-api.example.com
# Development only: set true when MOBILE_APP_URL is an http:// LAN address.
CAPACITOR_ALLOW_CLEARTEXT=false
